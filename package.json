{
  "name": "@keit/create-base",
  "version": "0.1.0",
  "description": "Interactive CLI to scaffold modern TypeScript/JavaScript projects with Biome, Husky, Commitlint, and more",
  "keywords": [
    "create",
    "scaffold",
    "template",
    "typescript",
    "javascript",
    "biome",
    "husky",
    "commitlint",
    "starter",
    "boilerplate"
  ],
  "author": "Keit",
  "license": "MIT",
  "type": "module",
  "main": "./dist/index.js",
  "bin": {
    "create-base": "./dist/index.js"
  },
  "files": [
    "dist",
    "templates"
  ],
  "scripts": {
    "build": "tsc",
    "dev": "tsc --watch",
    "test": "node --import tsx --test tests/**/*.test.ts",
    "knit": "knit",
    "prepublishOnly": "pnpm run typecheck && pnpm run lint && pnpm run knit && pnpm run test && pnpm build",
    "start": "node dist/index.js",
    "typecheck": "tsc --noEmit",
    "format": "biome format --write .",
    "lint": "biome lint .",
    "check": "biome check --write .",
    "release": "changelogen --release",
    "prepare": "husky"
  },
  "lint-staged": {
    "*.{js,ts,jsx,tsx,json,css}": "biome check --write --no-errors-on-unmatched",
    "*": "secretlint --secretlintignore .gitignore"
  },
  "engines": {
    "node": ">=20.0.0",
    "pnpm": ">=11.0.0"
  },
  "repository": {
    "type": "git",
    "url": "https://github.com/Keit32/create-base"
  },
  "bugs": {
    "url": "https://github.com/Keit32/create-base/issues"
  },
  "homepage": "https://github.com/Keit32/create-base#readme",
  "publishConfig": {
    "access": "public"
  },
  "dependencies": {
    "execa": "^9.6.1",
    "minimist": "^1.2.8",
    "picocolors": "^1.1.1",
    "prompts": "^2.4.2"
  },
  "devDependencies": {
    "@biomejs/biome": "^2.5.0",
    "@commitlint/cli": "^21.0.2",
    "@commitlint/config-conventional": "^21.0.2",
    "@secretlint/secretlint-rule-preset-recommend": "^13.0.2",
    "@types/minimist": "^1.2.5",
    "@types/node": "^25.9.3",
    "@types/prompts": "^2.4.9",
    "changelogen": "^0.6.2",
    "dotenv-vault": "^1.27.0",
    "husky": "^9.1.7",
    "knip": "^6.16.1",
    "lint-staged": "^17.0.7",
    "secretlint": "^13.0.2",
    "ts-node": "^10.9.2",
    "tsx": "^4.22.4",
    "typescript": "^6.0.3"
  }
}
